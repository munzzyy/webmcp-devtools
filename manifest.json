{
  "manifest_version": 3,
  "name": "WebMCP DevTools",
  "version": "0.1.0",
  "description": "Inspects the WebMCP tools (document.modelContext) a page exposes: live tool table, call-history timeline, and per-tool security diagnostics, in a real DevTools panel.",
  "minimum_chrome_version": "150",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "match_about_blank": false,
      "run_at": "document_start"
    }
  ],
  "permissions": [],
  "host_permissions": ["<all_urls>"]
}
